{
  // マルチルートワークスペース。
  // リポジトリのルートに加えて backend / infrastructures を「別々の根」として開く。
  // これにより mise 拡張が backend/mise.toml も文脈として解決し、
  // backend タスクの run ボタン / タスクツリーが使えるようになる。
  //
  // 使い方: Cursor で「File > Open Workspace from File...」からこのファイルを開く
  //        （または通知の「Open Workspace」ボタン）。
  "folders": [
    { "name": "root (repo)", "path": "." },
    { "name": "backend", "path": "backend" },
    { "name": "infrastructures", "path": "infrastructures" }
  ],
  "settings": {}
}
